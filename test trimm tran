`include "constants.h"
`include "discipline.h"

module trimm_cal (vout, bg_in, vbg_ok);

    parameter real    temp_test      = 27;    // working/test temperature (deg C)
    parameter real    temp_cal       = 150;   // calibration temperature (deg C)
    parameter real    temp_step      = 10;    // temperature ramp step (deg C)
    parameter integer cal_en         = 1;     // 1 = full trim sequence (TRAN), 0 = bypass, hold code_init (DC)
    parameter real    vddc           = 1.2;
    parameter real    target         = 1.22;  // target bandgap value
    parameter real    vbg_ok_th      = 1.0;   // vbg_ok threshold (capture + window-edge detect)
    parameter real    Tclk           = 1m;    // settle time per step
    parameter real    start_delay    = 1m;    // initial delay before action
    parameter real    post_cal_delay = 5m;    // hold best_code at temp_cal before ramping down
    parameter real    tt             = 1u;    // bit transition time
    parameter integer code_init      = 0 from [0:15];

    // ----- pull-phase parameters -----
    parameter real    pull_hi        = 1.4;   // upper target to pull bg_in toward (overvoltage probe)
    parameter real    pull_lo        = 1.0;   // lower target to pull bg_in toward (undervoltage probe)
    parameter real    R_pull         = 10k;   // finite series impedance for pulling (tune to source stiffness)
    parameter real    pull_slew      = 1e3;   // pull-voltage slew rate (V/s); slow ramp
    parameter real    pull_settle    = 5m;    // hold at start of pull phase before ramping

    output [3:0] vout;
    electrical [3:0] vout;

    inout bg_in;                 // now inout: we both sense and pull this node
    electrical bg_in;

    input vbg_ok;
    electrical vbg_ok;

    integer trim_val;
    integer out_code;
    integer step;
    integer state;
    integer post_cnt;
    integer ramp_cnt;
    integer ramp_ticks;
    integer ok_latched;
    integer pull_dir;     // 0 = idle/hold, +1 = ramping up to pull_hi, -1 = ramping down to pull_lo
    integer ov_latched;   // overvoltage edge captured
    integer uv_latched;   // undervoltage edge captured
    real    temp_cur;
    real    v_pull;       // commanded pull voltage (drives bg_in through R_pull)
    real    pull_target;  // current ramp target for v_pull

    // FSM states:
    localparam INIT_HOLD  = 0;
    localparam RAMP_UP    = 1;
    localparam CALIBRATE  = 2;
    localparam POST_DELAY = 3;
    localparam RAMP_DOWN  = 4;
    localparam DONE       = 5;
    localparam PULL_INIT  = 6;   // settle, set v_pull to current bg_in, start ramp up
    localparam PULL_UP    = 7;   // ramp v_pull up to pull_hi
    localparam PULL_DOWN  = 8;   // ramp v_pull down to pull_lo
    localparam PULL_DONE  = 9;

    (* desc="best trim code" *)               integer best_code;
    (* desc="monotonic normalized code" *)    integer norm_code;
    (* desc="best abs error", units="V" *)    real    best_err;
    (* desc="measured bandgap", units="V" *)  real    v_meas;
    (* desc="final bandgap at temp_test", units="V" *) real v_final;
    (* desc="bg_in captured at vbg_ok rising", units="V" *) real vbg_at_ok;
    (* desc="overvoltage trip (vbg_ok falls, rising bg_in)", units="V" *)  real v_ov;
    (* desc="undervoltage trip (vbg_ok falls, falling bg_in)", units="V" *) real v_uv;

    analog begin
        @(initial_step) begin
            best_code  = code_init;
            norm_code  = code_init ^ 8;
            trim_val   = 0;
            step       = 0;
            post_cnt   = 0;
            ramp_cnt   = 0;
            ok_latched = 0;
            ov_latched = 0;
            uv_latched = 0;
            pull_dir   = 0;
            best_err   = inf;
            v_meas     = 0;
            v_final    = 0;
            vbg_at_ok  = 0;
            v_ov       = 0;
            v_uv       = 0;
            v_pull     = 0;
            pull_target = 0;
            temp_cur   = temp_test;
            state      = INIT_HOLD;

            ramp_ticks = 21;

            if (cal_en)
                $cds_set_temperature(temp_cur);
        end

        // capture bg_in the first time vbg_ok rises past threshold, only during INIT_HOLD
        @(cross(V(vbg_ok) - vbg_ok_th, +1)) begin
            if (cal_en && !ok_latched && state == INIT_HOLD) begin
                vbg_at_ok  = V(bg_in);
                ok_latched = 1;
            end
        end

        // window-edge detection: catch vbg_ok FALLING past threshold during pull phases
        @(cross(V(vbg_ok) - vbg_ok_th, -1)) begin
            if (cal_en) begin
                if (state == PULL_UP && !ov_latched) begin
                    v_ov       = V(bg_in);     // overvoltage trip point
                    ov_latched = 1;
                end
                if (state == PULL_DOWN && !uv_latched) begin
                    v_uv       = V(bg_in);     // undervoltage trip point
                    uv_latched = 1;
                end
            end
        end

        // ===== cal_en = 1 : full sequence, transient only =====
        @(timer(start_delay, Tclk)) begin
            if (cal_en) begin
                case (state)

                    INIT_HOLD: begin
                        ramp_cnt = 0;
                        state    = RAMP_UP;
                    end

                    RAMP_UP: begin
                        if (abs(temp_cur - temp_cal) > temp_step) begin
                            if (temp_cal > temp_cur)
                                temp_cur = temp_cur + temp_step;
                            else
                                temp_cur = temp_cur - temp_step;
                            $cds_set_temperature(temp_cur);
                        end else if (temp_cur != temp_cal) begin
                            temp_cur = temp_cal;
                            $cds_set_temperature(temp_cur);
                        end
                        ramp_cnt = ramp_cnt + 1;
                        if (ramp_cnt >= ramp_ticks) begin
                            step  = 0;
                            state = CALIBRATE;
                        end
                    end

                    CALIBRATE: begin
                        if (step > 0) begin
                            v_meas = V(bg_in);
                            if (abs(v_meas - target) < best_err) begin
                                best_err  = abs(v_meas - target);
                                best_code = trim_val;
                                norm_code = trim_val ^ 8;
                            end
                        end
                        if (step < 16) begin
                            trim_val = step;
                            step     = step + 1;
                        end else begin
                            trim_val = best_code;
                            post_cnt = 0;
                            state    = POST_DELAY;
                        end
                    end

                    POST_DELAY: begin
                        post_cnt = post_cnt + 1;
                        if (post_cnt * Tclk >= post_cal_delay) begin
                            ramp_cnt = 0;
                            state    = RAMP_DOWN;
                        end
                    end

                    RAMP_DOWN: begin
                        if (abs(temp_cur - temp_test) > temp_step) begin
                            if (temp_test > temp_cur)
                                temp_cur = temp_cur + temp_step;
                            else
                                temp_cur = temp_cur - temp_step;
                            $cds_set_temperature(temp_cur);
                        end else if (temp_cur != temp_test) begin
                            temp_cur = temp_test;
                            $cds_set_temperature(temp_cur);
                        end
                        ramp_cnt = ramp_cnt + 1;
                        if (ramp_cnt >= ramp_ticks) begin
                            post_cnt = 0;
                            state    = DONE;
                        end
                    end

                    DONE: begin
                        v_final = V(bg_in);            // bandgap at temp_test, trimmed, before pulling
                        // settle a bit, then start pulling
                        post_cnt = post_cnt + 1;
                        if (post_cnt * Tclk >= pull_settle) begin
                            v_pull      = V(bg_in);   // start pull from current node voltage
                            pull_target = pull_hi;
                            pull_dir    = +1;
                            state       = PULL_UP;
                        end
                    end

                    PULL_UP: begin
                        // ramp handled continuously below; switch to down when target reached
                        if (v_pull >= pull_hi - 1e-6) begin
                            pull_target = pull_lo;
                            pull_dir    = -1;
                            state       = PULL_DOWN;
                        end
                    end

                    PULL_DOWN: begin
                        if (v_pull <= pull_lo + 1e-6) begin
                            pull_dir = 0;
                            state    = PULL_DONE;
                        end
                    end

                    PULL_DONE: begin
                        // hold; nothing more
                    end

                endcase
            end
        end

        // ===== continuous slewing of v_pull during pull phases =====
        // ramp v_pull toward pull_target at pull_slew (V/s)
        if (pull_dir > 0)
            v_pull = v_pull + pull_slew * Tclk;   // step per tick; fine because Tclk small vs span
        else if (pull_dir < 0)
            v_pull = v_pull - pull_slew * Tclk;
        // clamp
        if (v_pull > pull_hi) v_pull = pull_hi;
        if (v_pull < pull_lo) v_pull = pull_lo;

        // ===== output code selection =====
        if (cal_en)
            out_code = trim_val;
        else
            out_code = code_init;

        V(vout[0]) <+ transition(((out_code >> 0) & 1) * vddc, 0, tt);
        V(vout[1]) <+ transition(((out_code >> 1) & 1) * vddc, 0, tt);
        V(vout[2]) <+ transition(((out_code >> 2) & 1) * vddc, 0, tt);
        V(vout[3]) <+ transition(((out_code >> 3) & 1) * vddc, 0, tt);

        // ===== pull current into bg_in node (finite-impedance pull) =====
        // active only while pulling; otherwise R_pull ties v_pull(=node) -> ~no current
        if (cal_en && pull_dir != 0)
            I(bg_in) <+ (V(bg_in) - v_pull) / R_pull;

        @(final_step)
            $strobe("CAL_RESULT best_code=%d norm_code=%d best_err=%g v_final=%g vbg_at_ok=%g v_ov=%g v_uv=%g temp_test=%g",
                    best_code, norm_code, best_err, v_final, vbg_at_ok, v_ov, v_uv, temp_test);
    end

endmodule
