`include "constants.h"
`include "discipline.h"

module trimm_cal (vout, bg_in, vbg_ok);

    parameter real    temp_test      = 27;    // working/test temperature (deg C)
    parameter real    temp_cal       = 150;   // calibration temperature (deg C)
    parameter real    temp_step      = 10;    // temperature ramp step (deg C)
    parameter integer cal_en         = 1;     // 1 = full trim sequence (TRAN), 0 = bypass, hold code_init (DC)
    parameter real    vddc           = 1.2;
    parameter real    target         = 1.22;  // target bandgap value
    parameter real    vbg_ok_th      = 1.0;   // vbg_ok threshold (capture + window-edge detect)
    parameter real    Tclk           = 1m;    // settle time per step
    parameter real    start_delay    = 1m;    // initial delay before action
    parameter real    post_cal_delay = 5m;    // hold best_code at temp_cal before ramping down
    parameter real    tt             = 1u;    // bit transition time
    parameter integer code_init      = 0 from [0:15];

    // ----- pull-phase parameters -----
    parameter real    pull_hi        = 1.4;   // upper target (overvoltage probe)
    parameter real    pull_lo        = 1.0;   // lower target (undervoltage probe)
    parameter real    t_up           = 5m;    // time: start -> pull_hi
    parameter real    t_down         = 10m;   // time: pull_hi -> pull_lo
    parameter real    t_ret          = 5m;    // time: pull_lo -> start (return)
    parameter real    pull_settle    = 5m;    // hold after DONE before pulling
    parameter real    Gpull          = 1.0;   // servo transconductance (A/V); high = node follows target stiffly
    parameter real    Rrelax         = 1e9;   // huge resistance when released (effectively open)

    output [3:0] vout;
    electrical [3:0] vout;

    inout bg_in;                 // inout: sense and pull this node
    electrical bg_in;

    input vbg_ok;
    electrical vbg_ok;

    integer trim_val;
    integer out_code;
    integer step;
    integer state;
    integer post_cnt;
    integer ramp_cnt;
    integer ramp_ticks;
    integer ok_latched;
    integer ov_latched;
    integer uv_latched;
    integer pulling;        // 1 while servo drives the node
    real    temp_cur;
    real    v_tgt;          // target voltage the node should follow during pull
    real    v_start;        // bg_in value captured at pull-phase start (pre-pull)
    real    ph_t0;          // time current pull sub-phase began
    real    ph_v0;          // v_tgt at start of current pull sub-phase

    // FSM states:
    localparam INIT_HOLD  = 0;
    localparam RAMP_UP    = 1;
    localparam CALIBRATE  = 2;
    localparam POST_DELAY = 3;
    localparam RAMP_DOWN  = 4;
    localparam DONE       = 5;
    localparam PULL_UP    = 6;
    localparam PULL_DOWN  = 7;
    localparam PULL_RET   = 8;
    localparam PULL_DONE  = 9;

    (* desc="best trim code" *)               integer best_code;
    (* desc="monotonic normalized code" *)    integer norm_code;
    (* desc="best abs error", units="V" *)    real    best_err;
    (* desc="measured bandgap", units="V" *)  real    v_meas;
    (* desc="final bandgap at temp_test", units="V" *) real v_final;
    (* desc="bg_in captured at vbg_ok rising", units="V" *) real vbg_at_ok;
    (* desc="overvoltage trip (vbg_ok falls, rising bg_in)", units="V" *)  real v_ov;
    (* desc="undervoltage trip (vbg_ok falls, falling bg_in)", units="V" *) real v_uv;
    (* desc="commanded pull target", units="V" *) real v_tgt_dbg;

    analog begin
        @(initial_step) begin
            best_code  = code_init;
            norm_code  = code_init ^ 8;
            trim_val   = 0;
            step       = 0;
            post_cnt   = 0;
            ramp_cnt   = 0;
            ok_latched = 0;
            ov_latched = 0;
            uv_latched = 0;
            pulling    = 0;
            best_err   = inf;
            v_meas     = 0;
            v_final    = 0;
            vbg_at_ok  = 0;
            v_ov       = 0;
            v_uv       = 0;
            v_tgt      = 0;
            v_start    = 0;
            ph_t0      = 0;
            ph_v0      = 0;
            v_tgt_dbg  = 0;
            temp_cur   = temp_test;
            state      = INIT_HOLD;

            ramp_ticks = 21;

            if (cal_en)
                $cds_set_temperature(temp_cur);
        end

        // capture bg_in the first time vbg_ok rises past threshold, only during INIT_HOLD
        @(cross(V(vbg_ok) - vbg_ok_th, +1)) begin
            if (cal_en && !ok_latched && state == INIT_HOLD) begin
                vbg_at_ok  = V(bg_in);
                ok_latched = 1;
            end
        end

        // window-edge detection: catch vbg_ok FALLING past threshold during pull
        @(cross(V(vbg_ok) - vbg_ok_th, -1)) begin
            if (cal_en) begin
                if (state == PULL_UP && !ov_latched) begin
                    v_ov       = V(bg_in);
                    ov_latched = 1;
                end
                if (state == PULL_DOWN && !uv_latched) begin
                    v_uv       = V(bg_in);
                    uv_latched = 1;
                end
            end
        end

        // ===== cal_en = 1 : full sequence, transient only =====
        @(timer(start_delay, Tclk)) begin
            if (cal_en) begin
                case (state)

                    INIT_HOLD: begin
                        ramp_cnt = 0;
                        state    = RAMP_UP;
                    end

                    RAMP_UP: begin
                        if (abs(temp_cur - temp_cal) > temp_step) begin
                            if (temp_cal > temp_cur)
                                temp_cur = temp_cur + temp_step;
                            else
                                temp_cur = temp_cur - temp_step;
                            $cds_set_temperature(temp_cur);
                        end else if (temp_cur != temp_cal) begin
                            temp_cur = temp_cal;
                            $cds_set_temperature(temp_cur);
                        end
                        ramp_cnt = ramp_cnt + 1;
                        if (ramp_cnt >= ramp_ticks) begin
                            step  = 0;
                            state = CALIBRATE;
                        end
                    end

                    CALIBRATE: begin
                        if (step > 0) begin
                            v_meas = V(bg_in);
                            if (abs(v_meas - target) < best_err) begin
                                best_err  = abs(v_meas - target);
                                best_code = trim_val;
                                norm_code = trim_val ^ 8;
                            end
                        end
                        if (step < 16) begin
                            trim_val = step;
                            step     = step + 1;
                        end else begin
                            trim_val = best_code;
                            post_cnt = 0;
                            state    = POST_DELAY;
                        end
                    end

                    POST_DELAY: begin
                        post_cnt = post_cnt + 1;
                        if (post_cnt * Tclk >= post_cal_delay) begin
                            ramp_cnt = 0;
                            state    = RAMP_DOWN;
                        end
                    end

                    RAMP_DOWN: begin
                        if (abs(temp_cur - temp_test) > temp_step) begin
                            if (temp_test > temp_cur)
                                temp_cur = temp_cur + temp_step;
                            else
                                temp_cur = temp_cur - temp_step;
                            $cds_set_temperature(temp_cur);
                        end else if (temp_cur != temp_test) begin
                            temp_cur = temp_test;
                            $cds_set_temperature(temp_cur);
                        end
                        ramp_cnt = ramp_cnt + 1;
                        if (ramp_cnt >= ramp_ticks) begin
                            post_cnt = 0;
                            state    = DONE;
                        end
                    end

                    DONE: begin
                        v_final = V(bg_in);
                        post_cnt = post_cnt + 1;
                        if (post_cnt * Tclk >= pull_settle) begin
                            v_start = V(bg_in);       // pre-pull node voltage
                            v_tgt   = v_start;
                            ph_t0   = $abstime;
                            ph_v0   = v_start;
                            pulling = 1;
                            state   = PULL_UP;
                        end
                    end

                    PULL_UP: begin
                        if ($abstime - ph_t0 >= t_up) begin
                            ph_t0 = $abstime;
                            ph_v0 = pull_hi;
                            state = PULL_DOWN;
                        end
                    end

                    PULL_DOWN: begin
                        if ($abstime - ph_t0 >= t_down) begin
                            ph_t0 = $abstime;
                            ph_v0 = pull_lo;
                            state = PULL_RET;
                        end
                    end

                    PULL_RET: begin
                        if ($abstime - ph_t0 >= t_ret) begin
                            pulling = 0;
                            state   = PULL_DONE;
                        end
                    end

                    PULL_DONE: begin
                        // released
                    end

                endcase
            end
        end

        // ===== time-based target trajectory (continuous) =====
        if (state == PULL_UP)
            v_tgt = ph_v0 + (pull_hi - ph_v0) * ((($abstime - ph_t0) > t_up   ? t_up   : ($abstime - ph_t0)) / t_up);
        else if (state == PULL_DOWN)
            v_tgt = ph_v0 + (pull_lo - ph_v0) * ((($abstime - ph_t0) > t_down ? t_down : ($abstime - ph_t0)) / t_down);
        else if (state == PULL_RET)
            v_tgt = ph_v0 + (v_start - ph_v0) * ((($abstime - ph_t0) > t_ret  ? t_ret  : ($abstime - ph_t0)) / t_ret);

        v_tgt_dbg = v_tgt;

        // ===== output code selection =====
        if (cal_en)
            out_code = trim_val;
        else
            out_code = code_init;

        V(vout[0]) <+ transition(((out_code >> 0) & 1) * vddc, 0, tt);
        V(vout[1]) <+ transition(((out_code >> 1) & 1) * vddc, 0, tt);
        V(vout[2]) <+ transition(((out_code >> 2) & 1) * vddc, 0, tt);
        V(vout[3]) <+ transition(((out_code >> 3) & 1) * vddc, 0, tt);

        // ===== servo pull: force V(bg_in) to follow v_tgt =====
        // inject current proportional to error; high Gpull overrides the source so the node
        // actually reaches pull_hi / pull_lo regardless of supply stiffness.
        if (cal_en && pulling)
            I(bg_in) <+ Gpull * (V(bg_in) - v_tgt);   // current sinks/sources to drive node to v_tgt
        else
            I(bg_in) <+ V(bg_in) / Rrelax;            // effectively open when released

        @(final_step)
            $strobe("CAL_RESULT best_code=%d norm_code=%d best_err=%g v_final=%g vbg_at_ok=%g v_ov=%g v_uv=%g temp_test=%g",
                    best_code, norm_code, best_err, v_final, vbg_at_ok, v_ov, v_uv, temp_test);
    end

endmodule
