`include "constants.h"
`include "discipline.h"

module trimm_cal (vout, test_mode, bg_in);

    parameter real    temp_test      = 27;    // working/test temperature (deg C)
    parameter real    temp_cal       = 150;   // calibration temperature (deg C)
    parameter real    temp_step      = 10;    // temperature ramp step (deg C)
    parameter integer cal_en         = 1;     // 1 = full sequence (TRAN), 0 = bypass, hold code_init (DC)
    parameter real    vddc           = 1.2;   // logic high level
    parameter real    target         = 1.22;  // target bandgap value
    parameter real    Tclk           = 1m;    // settle time per step
    parameter real    start_delay    = 1m;    // initial delay before action
    parameter real    post_cal_delay = 5m;    // hold best_code at temp_cal before ramping down
    parameter real    test_settle    = 5m;    // hold after DONE before entering test mode
    parameter real    tt             = 1u;    // bit transition time
    parameter integer code_init      = 0 from [0:15];

    output [3:0] vout;
    electrical [3:0] vout;

    output test_mode;            // drives bandgap into coarse-LSB test mode
    electrical test_mode;

    input bg_in;
    electrical bg_in;

    integer trim_val;     // code driven during calibration / test sweep
    integer out_code;     // code actually driven to vout
    integer tm_on;        // 1 = test mode asserted
    integer step;         // calibration sub-step counter
    integer tstep;        // test-sweep code index
    integer state;
    integer post_cnt;
    integer ramp_cnt;
    integer ramp_ticks;
    real    temp_cur;

    // FSM states:
    localparam INIT_HOLD  = 0;
    localparam RAMP_UP    = 1;   // ramp temp_test -> temp_cal
    localparam CALIBRATE  = 2;   // sweep codes at temp_cal, find best
    localparam POST_DELAY = 3;   // hold best_code at temp_cal
    localparam RAMP_DOWN  = 4;   // ramp temp_cal -> temp_test
    localparam DONE       = 5;   // hold best_code at temp_test, settle
    localparam TEST_ENTER = 6;   // set code 0, assert test_mode
    localparam TEST_HOLD0 = 7;   // hold code 0 for one frame before stepping
    localparam TEST_UP    = 8;   // walk 0 -> 7   (lower half, voltage rising)
    localparam TEST_JUMP  = 9;   // jump to 15, hold one frame
    localparam TEST_DN    = 10;  // walk 15 -> 8  (upper half, voltage falling)
    localparam TEST_EXIT  = 11;  // deassert test mode, restore best_code

    (* desc="best trim code" *)               integer best_code;
    (* desc="monotonic normalized code" *)    integer norm_code;
    (* desc="best abs error", units="V" *)    real    best_err;
    (* desc="measured bandgap", units="V" *)  real    v_meas;
    (* desc="final bandgap at temp_test", units="V" *) real v_final;

    analog begin
        @(initial_step) begin
            best_code = code_init;
            norm_code = code_init ^ 8;
            trim_val  = 0;
            tm_on     = 0;
            step      = 0;
            tstep     = 0;
            post_cnt  = 0;
            ramp_cnt  = 0;
            best_err  = inf;
            v_meas    = 0;
            v_final   = 0;
            temp_cur  = temp_test;
            state     = INIT_HOLD;

            ramp_ticks = 21;      // fixed ramp window (covers -40..150 worst case)

            if (cal_en)
                $cds_set_temperature(temp_cur);
        end

        @(timer(start_delay, Tclk)) begin
            if (cal_en) begin
                case (state)

                    INIT_HOLD: begin
                        ramp_cnt = 0;
                        state    = RAMP_UP;
                    end

                    RAMP_UP: begin
                        if (abs(temp_cur - temp_cal) > temp_step) begin
                            if (temp_cal > temp_cur)
                                temp_cur = temp_cur + temp_step;
                            else
                                temp_cur = temp_cur - temp_step;
                            $cds_set_temperature(temp_cur);
                        end else if (temp_cur != temp_cal) begin
                            temp_cur = temp_cal;
                            $cds_set_temperature(temp_cur);
                        end
                        ramp_cnt = ramp_cnt + 1;
                        if (ramp_cnt >= ramp_ticks) begin
                            step  = 0;
                            state = CALIBRATE;
                        end
                    end

                    CALIBRATE: begin
                        if (step > 0) begin
                            v_meas = V(bg_in);
                            if (abs(v_meas - target) < best_err) begin
                                best_err  = abs(v_meas - target);
                                best_code = trim_val;
                                norm_code = trim_val ^ 8;
                            end
                        end
                        if (step < 16) begin
                            trim_val = step;
                            step     = step + 1;
                        end else begin
                            trim_val = best_code;
                            post_cnt = 0;
                            state    = POST_DELAY;
                        end
                    end

                    POST_DELAY: begin
                        post_cnt = post_cnt + 1;
                        if (post_cnt * Tclk >= post_cal_delay) begin
                            ramp_cnt = 0;
                            state    = RAMP_DOWN;
                        end
                    end

                    RAMP_DOWN: begin
                        if (abs(temp_cur - temp_test) > temp_step) begin
                            if (temp_test > temp_cur)
                                temp_cur = temp_cur + temp_step;
                            else
                                temp_cur = temp_cur - temp_step;
                            $cds_set_temperature(temp_cur);
                        end else if (temp_cur != temp_test) begin
                            temp_cur = temp_test;
                            $cds_set_temperature(temp_cur);
                        end
                        ramp_cnt = ramp_cnt + 1;
                        if (ramp_cnt >= ramp_ticks) begin
                            post_cnt = 0;
                            state    = DONE;
                        end
                    end

                    DONE: begin
                        v_final  = V(bg_in);      // trimmed bandgap at temp_test
                        post_cnt = post_cnt + 1;
                        if (post_cnt * Tclk >= test_settle)
                            state = TEST_ENTER;
                    end

                    TEST_ENTER: begin
                        trim_val = 0;             // code 0000
                        tm_on    = 1;             // assert test mode (coarse LSB)
                        tstep    = 0;
                        state    = TEST_HOLD0;
                    end

                    TEST_HOLD0: begin
                        // hold code 0 for one frame so it settles before stepping up
                        state = TEST_UP;
                    end

                    TEST_UP: begin
                        // lower half, voltage rising: 0 -> 7
                        if (tstep < 7) begin
                            tstep    = tstep + 1;
                            trim_val = tstep;
                        end else begin
                            state = TEST_JUMP;
                        end
                    end

                    TEST_JUMP: begin
                        // jump straight to top of the other branch, hold one frame
                        tstep    = 15;
                        trim_val = 15;
                        state    = TEST_DN;
                    end

                    TEST_DN: begin
                        // upper half, voltage falling: 15 -> 8
                        if (tstep > 8) begin
                            tstep    = tstep - 1;
                            trim_val = tstep;
                        end else begin
                            state = TEST_EXIT;
                        end
                    end

                    TEST_EXIT: begin
                        tm_on    = 0;             // leave test mode
                        trim_val = best_code;     // restore trimmed code
                    end

                endcase
            end
        end

        // ===== output code selection =====
        // cal_en = 0 : bypass, hold code_init from t=0 (works in DC)
        if (cal_en)
            out_code = trim_val;
        else
            out_code = code_init;

        V(vout[0]) <+ transition(((out_code >> 0) & 1) * vddc, 0, tt);
        V(vout[1]) <+ transition(((out_code >> 1) & 1) * vddc, 0, tt);
        V(vout[2]) <+ transition(((out_code >> 2) & 1) * vddc, 0, tt);
        V(vout[3]) <+ transition(((out_code >> 3) & 1) * vddc, 0, tt);

        V(test_mode) <+ transition(tm_on * vddc, 0, tt);

        @(final_step)
            $strobe("CAL_RESULT best_code=%d norm_code=%d best_err=%g v_final=%g temp_test=%g",
                    best_code, norm_code, best_err, v_final, temp_test);
    end

endmodule
