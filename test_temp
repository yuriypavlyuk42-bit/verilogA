// VerilogA — physical R + L shunt, current source drives current THROUGH the L
`include "constants.vams"
`include "disciplines.vams"

module hs_shunt_rl(outp, outn, imon);

    output outp, outn, imon;
    electrical outp, outn, imon;
    electrical mid;                                  // node between R and L

    parameter real    rsh     = 1m     from (0:inf);
    parameter real    lesl    = 1.5n   from [0:inf);
    parameter real    vcm     = 48.0;
    parameter real    fsw     = 500k   from (0:inf);
    parameter real    duty    = 0.0167 from (0:1);
    parameter real    imin    = 5.0;
    parameter real    ipk     = 15.0;
    parameter real    t_comm  = 1n     from (0:inf);
    parameter real    t_delay = 0.0    from [0:inf);
    parameter integer n_pulses= 0      from [0:inf);

    real tper, ton, tloc, tph, ii;
    integer k, active;

    analog begin
        tper = 1.0/fsw;
        ton  = duty*tper;
        @(timer(t_delay, tper)) ;

        tloc = $abstime - t_delay;
        k    = floor(tloc/tper);
        tph  = tloc - k*tper;
        active = (tloc >= 0.0) && (n_pulses == 0 || k < n_pulses);

        if (!active)                       ii = 0.0;
        else if (tph < t_comm)             ii = imin*(tph/t_comm);
        else if (tph < t_comm + ton)       ii = imin + (ipk-imin)*((tph-t_comm)/ton);
        else if (tph < 2.0*t_comm + ton)   ii = ipk*(1.0 - (tph-t_comm-ton)/t_comm);
        else                               ii = 0.0;

        // force the pulse current into node outp (from an ideal source to ground-ref cm)
        I(outp) <+ -ii;                    // current source: ii flows INTO outp

        // series path outp -> mid -> outn carries that current:
        V(outp, mid) <+ lesl*ddt(I(outp, mid));   // L on top
        I(mid, outn) <+ V(mid, outn)/rsh;         // R on bottom
        V(outn)      <+ vcm;                        // bottom at CM

        V(imon) <+ ii;

        if (active && tph < 2.0*t_comm + ton) $bound_step(t_comm/4.0);
        else                                  $bound_step(tper/20.0);
    end
endmodule
